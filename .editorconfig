root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = tab
indent_size = 4

[*.{kts,gradle}]
indent_style = tab
indent_size = 4

[*.{yml,yaml,json,md,sql}]
indent_style = space
indent_size = 2

[*.{js,jsx,ts,tsx,css}]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

# Copy to .env and adjust. Never commit the real .env.
# These are consumed by docker-compose and (via the same names) the core-bank app.

DB_NAME=ledgerbank
DB_USERNAME=ledgerbank
DB_PASSWORD=ledgerbank

# Host port the core-bank API is published on (container always listens on 8080).
APP_PORT=8080

# Keycloak (identity provider).
KEYCLOAK_PORT=8088
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
